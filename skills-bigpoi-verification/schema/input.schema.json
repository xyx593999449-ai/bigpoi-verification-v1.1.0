{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ft-git.sf-express.com/ft-scaffold/ai-skills/schemas/input.schema.json",
  "title": "POI核实输入数据模式",
  "description": "定义大POI核实技能的输入数据标准化格式（兼容读库技能输出格式）",
  "type": "object",
  "required": ["id", "name", "poi_type", "city"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "任务唯一ID（来自原始表poi_init）",
      "minLength": 1,
      "maxLength": 64,
      "examples": ["TASK_20260227_001", "TASK_20240303_12345"]
    },
    "id": {
      "type": "string",
      "description": "POI业务ID（对应原始表的id字段）",
      "minLength": 1,
      "maxLength": 64,
      "examples": ["POI_001", "HOSPITAL_BJ_001"]
    },
    "poi_id": {
      "type": "string",
      "description": "POI唯一标识符（兼容字段，优先使用id）",
      "minLength": 1,
      "maxLength": 64,
      "examples": ["POI_202401150001", "HOSPITAL_BJ_001"],
      "deprecated": true,
      "x-deprecated-message": "请使用id字段替代poi_id字段"
    },
    "name": {
      "type": "string",
      "description": "POI名称",
      "minLength": 1,
      "maxLength": 200,
      "examples": ["北京大学第一医院", "北京市人民政府"]
    },
    "poi_type": {
      "type": "string",
      "description": "POI类型代码（公司内部类型代码，如090101）",
      "minLength": 1,
      "maxLength": 20,
      "examples": ["090101", "130501", "010101"],
      "pattern": "^\\d{6}$"
    },
    "city": {
      "type": "string",
      "description": "所属城市",
      "minLength": 1,
      "maxLength": 100,
      "examples": ["北京市", "上海市", "武汉市"]
    },
    "city_adcode": {
      "type": "string",
      "description": "城市编码（行政区划代码）",
      "minLength": 1,
      "maxLength": 20,
      "examples": ["110100", "310100", "420100"],
      "pattern": "^\\d{6}$"
    },
    "address": {
      "type": "string",
      "description": "详细地址",
      "maxLength": 500,
      "examples": ["北京市西城区西什库大街8号"]
    },
    "x_coord": {
      "type": "number",
      "description": "经度坐标（GCJ02坐标系）- 推荐使用 coordinates 对象",
      "minimum": 73.5,
      "maximum": 135.1,
      "examples": [116.3723, 121.4737]
    },
    "y_coord": {
      "type": "number",
      "description": "纬度坐标（GCJ02坐标系）- 推荐使用 coordinates 对象",
      "minimum": 3.5,
      "maximum": 53.6,
      "examples": [39.9342, 31.2304]
    },
    "coordinates": {
      "type": "object",
      "description": "地理坐标信息（推荐格式，与 record.schema.final_values 保持一致）",
      "properties": {
        "longitude": {
          "type": "number",
          "description": "经度",
          "minimum": 73.5,
          "maximum": 135.1,
          "examples": [116.3974]
        },
        "latitude": {
          "type": "number",
          "description": "纬度",
          "minimum": 3.5,
          "maximum": 53.6,
          "examples": [39.9042]
        },
        "coordinate_system": {
          "type": "string",
          "description": "坐标系类型",
          "enum": ["WGS84", "GCJ02", "BD09"],
          "default": "GCJ02"
        }
      },
      "required": ["longitude", "latitude"]
    },
    "phone": {
      "type": "string",
      "description": "联系电话",
      "pattern": "^1[3-9]\\d{9}$|^(0\\d{2,3}-?)?\\d{7,8}$",
      "examples": ["010-12345678"]
    },
    "website": {
      "type": "string",
      "description": "官方网站",
      "format": "uri",
      "maxLength": 500,
      "examples": ["https://www.pkuhospital.com"]
    },
    "postcode": {
      "type": "string",
      "description": "邮政编码",
      "pattern": "^\\d{6}$",
      "examples": ["100034"]
    },
    "source": {
      "type": "string",
      "description": "数据来源",
      "maxLength": 100,
      "examples": ["用户采集", "第三方数据", "官方导入"]
    },
    "collect_time": {
      "type": "string",
      "description": "数据采集时间",
      "format": "date-time",
      "examples": ["2024-01-15T08:30:00Z"]
    },
    "remark": {
      "type": "string",
      "description": "备注信息",
      "maxLength": 1000,
      "examples": ["原名为北京大学第一医院，2023年更名"]
    },
    "tags": {
      "type": "array",
      "description": "标签列表",
      "items": {
        "type": "string",
        "maxLength": 50
      },
      "examples": [["三甲", "综合医院", "医保定点"]]
    },
    "metadata": {
      "type": "object",
      "description": "扩展元数据",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "task_id": "TASK_20260227_001",
      "id": "POI_123",
      "name": "北京大学第一医院",
      "poi_type": "090101",
      "city": "北京市",
      "city_adcode": "110102",
      "address": "北京市西城区西什库大街8号",
      "coordinates": {
        "longitude": 116.3723,
        "latitude": 39.9342,
        "coordinate_system": "GCJ02"
      },
      "phone": "010-83572211",
      "postcode": "100034",
      "source": "官方导入"
    }
  ]
}
