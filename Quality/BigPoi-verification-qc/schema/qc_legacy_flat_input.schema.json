{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QC Legacy Flat Input Schema",
  "description": "Legacy flat input accepted by BigPOI verification QC before normalization.",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "poi_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "x_coord": {
      "type": ["number", "string"]
    },
    "y_coord": {
      "type": ["number", "string"]
    },
    "poi_type": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "district": {
      "type": "string"
    },
    "province": {
      "type": "string"
    },
    "city_adcode": {
      "type": "string"
    },
    "poi_status": {
      "type": ["boolean", "integer", "string"]
    },
    "verify_result": {
      "type": "string"
    },
    "quality_status": {
      "type": "string"
    },
    "batch_id": {
      "type": "string"
    },
    "worker_id": {
      "type": ["integer", "string"]
    },
    "verify_info": {
      "type": "object",
      "properties": {
        "existence": {
          "$ref": "#/definitions/legacy_dimension"
        },
        "name": {
          "$ref": "#/definitions/legacy_dimension"
        },
        "location": {
          "$ref": "#/definitions/legacy_dimension"
        },
        "administrative": {
          "$ref": "#/definitions/legacy_dimension"
        },
        "category": {
          "$ref": "#/definitions/legacy_dimension"
        }
      },
      "additionalProperties": true
    },
    "evidence_record": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/legacy_evidence"
      }
    }
  },
  "required": ["task_id", "name", "address", "x_coord", "y_coord", "poi_type", "evidence_record"],
  "additionalProperties": true,
  "definitions": {
    "legacy_dimension": {
      "type": "object",
      "properties": {
        "result": {
          "type": "string"
        },
        "confidence": {
          "type": ["number", "string"]
        },
        "score": {
          "type": ["number", "string"]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "details": {
          "type": ["object", "string"]
        }
      },
      "additionalProperties": true
    },
    "legacy_evidence": {
      "type": "object",
      "properties": {
        "evidence_id": {
          "type": "string"
        },
        "poi_id": {
          "type": "string"
        },
        "source": {
          "type": "object",
          "properties": {
            "source_id": {
              "type": "string"
            },
            "source_name": {
              "type": "string"
            },
            "source_type": {
              "type": "string"
            },
            "source_url": {
              "type": "string"
            },
            "weight": {
              "type": ["number", "string"]
            }
          },
          "additionalProperties": true
        },
        "data": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "category": {
              "type": "string"
            },
            "location": {
              "type": "object"
            },
            "coordinates": {
              "type": "object"
            },
            "administrative": {
              "type": "object"
            },
            "raw_data": {
              "type": "object"
            }
          },
          "additionalProperties": true
        },
        "verification": {
          "type": "object",
          "properties": {
            "is_valid": {
              "type": "boolean"
            },
            "confidence": {
              "type": ["number", "string"]
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["evidence_id", "source", "data", "verification"],
      "additionalProperties": true
    }
  }
}
