{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Triggered Rules Schema",
  "description": "Triggered rules schema for BigPOI QC v2.0.0",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["rule_id", "rule_name", "dimension"],
    "properties": {
      "rule_id": {
        "type": "string",
        "enum": ["R1", "R2", "R3", "R4", "R5", "R6", "R7"]
      },
      "rule_name": {
        "type": "string"
      },
      "severity": {
        "type": "string",
        "enum": ["critical", "high", "medium", "low"]
      },
      "dimension": {
        "type": "string",
        "enum": ["existence", "name", "location", "address", "administrative", "category", "downgrade_consistency"]
      }
    },
    "additionalProperties": false
  }
}
